# FusionBid 智标聚合助手 - 环境变量示例
# 复制为 .env 后按需修改。切勿将真实 API Key 提交到 Git。
# 大模型双模式说明见 docs/LLM双模式配置.md

# 应用
APP_NAME=FusionBid智标聚合助手
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_TIMEZONE=Asia/Shanghai
APP_VERSION=1.0.0
APP_PHASE=phase8-integration

# 数据库：留空则使用默认 data/fusion_bid.db（相对项目根）
# DATABASE_URL=sqlite+aiosqlite:///F:/path/to/data/fusion_bid.db

# CORS（开发前后端分离时需要；一键启动同端口可保持默认）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8000,http://localhost:8000

# 路径（相对项目根）
DATA_DIR=./data
REPORTS_DIR=./data/reports
BROWSER_STATES_DIR=./data/browser_states
FIXTURES_DIR=./data/fixtures

# ========== 大模型：优先 API，其次 Ollama，最后规则 ==========
LLM_PREFER_ORDER=api,ollama,rule
LLM_ENABLED=true

# --- OpenAI 兼容 API（请勿把真实 Key 打进发布包）---
# 也可启动后在 Web「设置」页填写，存本地 data/llm_secrets.json
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=60

# --- 本地 Ollama ---
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=120

# 采集通用
HTTP_TIMEOUT=30
HTTP_MAX_RETRIES=3
CRAWL_MAX_CONCURRENCY=3
CRAWL_RATE_LIMIT_PER_SECOND=1

# CEBPUB 详情默认由 FusionBid 自动管理独立 Chrome/Edge；状态只保存在本机忽略目录
CEBPUB_BROWSER_MODE=managed
CEBPUB_BROWSER_TIMEOUT_SECONDS=60

# ========== 登录态数据源 ==========
LOGIN_SOURCE_ENABLED=true
LOGIN_SOURCE_HOME_URL=https://www.chinabidding.cn/
LOGIN_SOURCE_LOGIN_URL=https://www.chinabidding.cn/
LOGIN_SOURCE_SEARCH_URL=https://www.chinabidding.cn/search/?q={keyword}
LOGIN_SOURCE_STATE_FILE=login_portal_state.json
LOGIN_SOURCE_MAX_ITEMS=10
LOGIN_SOURCE_LOGIN_MARKERS=请登录,登录后查看,立即登录,用户登录,会员登录
LOGIN_SOURCE_LOGGED_IN_MARKERS=退出登录,安全退出,个人中心,我的账号,注销

# 前端构建时 API 基址：一键启动同域请留空
# VITE_API_BASE_URL=
